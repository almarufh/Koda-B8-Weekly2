                    <div class="mf-box-socials">
                        <div class="mf-box-social">
                            <img src="/assets/facebook.svg" alt="Facebook">
                        </div>
                        <div class="mf-box-social">
                            <img src="/assets/instagram.svg" alt="Instagram">
                        </div>
                        <div class="mf-box-social">
                            <img src="/assets/x.svg" alt="Twitter">
                        </div>
                        <div class="mf-box-social">
