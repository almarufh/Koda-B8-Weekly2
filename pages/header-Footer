                    <div class="mf-box-contacts">
                        <div class="mf-box-contact">
                            <img src="/assets/map2.svg" alt="Map">
                            <span>Jl. Sudirman No. 1, Jakarta Selatan, DKI
                        Jakarta 12190</span>
                        </div>
                        <div class="mf-box-contact">
                            <img src="/assets/telp.svg" alt="Telepon">
                            <span>0800-1234-5678 (Gratis)</span>
                        </div>
                        <div class="mf-box-contact">
                            <img src="/assets/gmail.svg" alt="Gmail">
                            <span>bantuan@belimudah.id</span>
                        </div>
                        <div class="contact-complain">
                            <span class="complain-newslater">Newsletter</span>
                            <div class="newslatter">
                                <input type="text" value="Email kamu">
                                <button>Langganan</button>
                            </div>
                        </div>
                    </div>
                </div>
